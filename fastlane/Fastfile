default_platform(:ios)

# Keep shared lane helpers in this file so Fastlane import_from_git consumers only
# need to fetch fastlane/Fastfile. Fastlane evaluates imported Fastfiles in the
# consuming app context, where this repo's fastlane/helpers directory is not
# present.
def asc_api_key
  app_store_connect_api_key(
    key_id:       ENV.fetch("ASC_KEY_ID"),
    issuer_id:    ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: File.expand_path(
      "~/.appstoreconnect/private_keys/AuthKey_#{ENV.fetch('ASC_KEY_ID')}.p8"
    ),
    duration:  1200,
    in_house:  false
  )
end

# extra_bundles: array of [bundle_id, target_name] pairs.
# Built from the deploy lane's extra_bundle_ids option, which is a space-separated
# list of "bundle_id=target_name" strings (e.g. "net.dinglebox.cabinetdoor.Clip=epac-clip").
# Apps without extensions pass extra_bundle_ids:"" and extra_bundles becomes [].
def bake_manual_signing(xcodeproj:, team_id:, primary_target:, primary_bundle:, extra_bundles:, api_key:)
  all_bundles = [[primary_bundle, primary_target]] + extra_bundles

  all_bundles.each do |bundle_id, target_name|
    profile_uuid = sigh(
      api_key:        api_key,
      app_identifier: bundle_id,
      force:          false
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  xcodeproj,
      team_id:               team_id,
      targets:               [target_name],
      code_sign_identity:    "Apple Distribution",
      profile_uuid:          profile_uuid
    )
  end
end

platform :ios do
  desc "Upload App Store metadata (no binary, no review submission)"
  lane :deliver do
    api_key = asc_api_key

    upload_to_app_store(
      api_key:            api_key,
      skip_binary_upload: true,
      submit_for_review:  false,
      force:              true,
      metadata_path:      "./fastlane/metadata",
      screenshots_path:   "./fastlane/screenshots",
      skip_screenshots:   true
    )
  end

  desc "Build release archive and upload to TestFlight"
  lane :deploy do |options|
    scheme           = options.fetch(:scheme)
    bundle_id        = options.fetch(:bundle_id)
    team_id          = options.fetch(:team_id)
    xcodeproj        = options.fetch(:xcodeproj)
    extra_bundle_ids = options.fetch(:extra_bundle_ids, "")
    lane_workdir     = Dir.pwd

    api_key = asc_api_key

    next_build = (latest_testflight_build_number(api_key: api_key) rescue 0) + 1
    increment_build_number(build_number: next_build, xcodeproj: xcodeproj)
    File.write(File.join(lane_workdir, "build_number.txt"), next_build.to_s)

    new_version = ENV.fetch("NEW_VERSION", "")
    unless new_version.empty?
      increment_version_number(version_number: new_version, xcodeproj: xcodeproj)
    end

    # extra_bundle_ids is space-separated "bundle_id=target_name" pairs.
    extra_bundles = extra_bundle_ids.split.map { |pair| pair.split("=", 2) }

    bake_manual_signing(
      xcodeproj:      xcodeproj,
      team_id:        team_id,
      primary_target: scheme,
      primary_bundle: bundle_id,
      extra_bundles:  extra_bundles,
      api_key:        api_key
    )

    sentry_dsn = ENV.fetch("SENTRY_DSN", "")
    xcargs = "DEVELOPMENT_TEAM=#{team_id} CURRENT_PROJECT_VERSION=#{next_build} SENTRY_DSN=#{sentry_dsn}"
    xcargs = "#{xcargs} MARKETING_VERSION=#{new_version}" unless new_version.empty?

    build_app(
      scheme:           scheme,
      configuration:    "Release",
      destination:      "generic/platform=iOS",
      export_method:    "app-store",
      xcargs:           xcargs,
      output_directory: "build",
      output_name:      "#{scheme}.ipa",
      clean:            true
    )

    upload_to_testflight(
      api_key:                           api_key,
      ipa:                               "build/#{scheme}.ipa",
      skip_waiting_for_build_processing: true,
      distribute_external:               false,
      notify_external_testers:           false
    )
  end
end
